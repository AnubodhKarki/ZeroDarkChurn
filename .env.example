# LLM provider selection — change this to swap providers without touching code
# Supported values: openai, anthropic
LLM_PROVIDER=openai

# Optional: override the default model for the selected provider
# Leave blank to use the provider's default (gpt-4o-mini for OpenAI, claude-sonnet-4-5 for Anthropic)
LLM_MODEL=

# API keys — fill in the one that matches your LLM_PROVIDER
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
